<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Para Você, Meu Amor ❤️</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Playfair+Display:ital,wght@0,400;0,600;1,400;1,500&family=Quicksand:wght@300;400&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            background: radial-gradient(ellipse at 30% 20%, #1e0e1a, #0a0408 80%);
            font-family: 'Playfair Display', Georgia, serif;
            padding: 30px 20px 50px;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            position: relative;
            overflow-x: hidden;
        }

        /* Pétalas */
        .petals {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }

        .petal {
            position: absolute;
            top: -60px;
            font-size: 24px;
            opacity: 0.2;
            animation: cair linear infinite;
            color: #ff6b8a;
        }

        .petal:nth-child(1) { left: 5%; font-size: 22px; animation-duration: 14s; animation-delay: 0s; }
        .petal:nth-child(2) { left: 15%; font-size: 30px; animation-duration: 17s; animation-delay: 2s; }
        .petal:nth-child(3) { left: 25%; font-size: 18px; animation-duration: 11s; animation-delay: 4s; }
        .petal:nth-child(4) { left: 35%; font-size: 28px; animation-duration: 15s; animation-delay: 1s; }
        .petal:nth-child(5) { left: 45%; font-size: 20px; animation-duration: 12s; animation-delay: 3s; }
        .petal:nth-child(6) { left: 55%; font-size: 32px; animation-duration: 18s; animation-delay: 5s; }
        .petal:nth-child(7) { left: 65%; font-size: 24px; animation-duration: 13s; animation-delay: 0.5s; }
        .petal:nth-child(8) { left: 75%; font-size: 28px; animation-duration: 16s; animation-delay: 3.5s; }
        .petal:nth-child(9) { left: 85%; font-size: 20px; animation-duration: 12s; animation-delay: 2s; }
        .petal:nth-child(10) { left: 92%; font-size: 26px; animation-duration: 14s; animation-delay: 4s; }

        @keyframes cair {
            0% { transform: translateY(0) rotate(0deg) scale(1); opacity: 0.05; }
            20% { opacity: 0.2; }
            100% { transform: translateY(110vh) rotate(720deg) scale(0.5); opacity: 0; }
        }

        /* Container principal */
        .container {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 1000px;
            background: rgba(255, 245, 240, 0.04);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border: 1px solid rgba(255, 200, 215, 0.06);
            border-radius: 70px;
            padding: 50px 60px 40px;
            box-shadow: 0 40px 100px rgba(0, 0, 0, 0.6);
        }

        /* Título */
        .topo {
            text-align: center;
            margin-bottom: 30px;
        }

        .icone {
            font-size: 54px;
            display: block;
            animation: pulse 2.8s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1) rotate(0); }
            30% { transform: scale(1.1) rotate(-4deg); }
            60% { transform: scale(0.95) rotate(0); }
            80% { transform: scale(1.05) rotate(4deg); }
        }

        h1 {
            font-family: 'Great Vibes', cursive;
            font-weight: 400;
            font-size: clamp(2.5rem, 7vw, 3.8rem);
            background: linear-gradient(135deg, #f5d4df, #ffb3c9);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradiente 6s ease infinite;
            letter-spacing: 1px;
            line-height: 1.2;
        }

        @keyframes gradiente {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }

        .sub {
            font-family: 'Quicksand', sans-serif;
            font-weight: 300;
            font-size: clamp(0.7rem, 1.2vw, 0.95rem);
            color: #c99aab;
            letter-spacing: 12px;
            text-transform: uppercase;
            opacity: 0.4;
            margin-top: 4px;
        }

        .divisoria {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 24px;
            margin: 16px auto 22px;
            opacity: 0.15;
        }

        .divisoria .linha {
            width: 100px;
            height: 1px;
            background: linear-gradient(to right, transparent, #ff8099, transparent);
        }

        .divisoria .coracao {
            color: #ff8099;
            font-size: 20px;
            animation: brilho 3s infinite alternate;
        }

        @keyframes brilho {
            0% { opacity: 0.2; transform: scale(0.8); }
            100% { opacity: 0.9; transform: scale(1.2); }
        }

        /* Texto */
        .texto {
            font-family: 'Playfair Display', Georgia, serif;
            font-size: clamp(1.05rem, 1.4vw, 1.25rem);
            line-height: 2.4;
            color: #f0e2ea;
            text-align: justify;
            padding: 0 4px;
            width: 100%;
        }

        .texto p {
            margin-bottom: 24px;
            text-indent: 3em;
            opacity: 0;
            transform: translateY(40px);
            transition: all 0.9s ease;
            padding: 4px 8px;
            border-radius: 6px;
            word-wrap: break-word;
        }

        .texto p.revelado {
            opacity: 1;
            transform: translateY(0);
        }

        .texto .destaque {
            color: #ffc8d8;
            font-weight: 500;
            font-style: italic;
        }

        .texto .destaque-forte {
            font-weight: 600;
            font-style: italic;
            background: linear-gradient(135deg, #ff8aa8, #ffb3c9);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: brilho-palavra 3s infinite;
        }

        @keyframes brilho-palavra {
            0%, 100% { opacity: 0.8; }
            50% { opacity: 1; }
        }

        .texto .emoji {
            font-style: normal;
            font-size: 1.15em;
            -webkit-text-fill-color: initial;
        }

        .texto .grito {
            color: #ffb3c9;
            font-size: 1.2em;
            font-weight: 500;
            -webkit-text-fill-color: #ffb3c9;
        }

        /* ===== ENVELOPE - VERSÃO SIMPLES E FUNCIONAL ===== */
        .envelope-wrapper {
            margin-top: 50px;
            display: flex;
            justify-content: center;
            width: 100%;
        }

        .envelope-box {
            width: 340px;
            max-width: 90%;
            cursor: pointer;
            position: relative;
            border-radius: 12px;
            background: linear-gradient(145deg, #f5d4df, #e8b4c4);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
            overflow: hidden;
            transition: all 0.4s ease;
            border: 2px solid rgba(255, 200, 215, 0.2);
        }

        .envelope-box:hover {
            transform: scale(1.02);
            box-shadow: 0 16px 50px rgba(255, 80, 130, 0.15);
        }

        /* Tampa do envelope */
        .envelope-tampa {
            background: linear-gradient(145deg, #fce8ee, #e8b4c4);
            padding: 18px 10px 14px;
            text-align: center;
            border-bottom: 2px dashed rgba(255, 200, 215, 0.3);
            transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
            position: relative;
            z-index: 2;
        }

        .envelope-tampa .selo {
            font-size: 42px;
            display: block;
            animation: pulse 2.8s infinite;
            filter: drop-shadow(0 0 10px rgba(255, 80, 130, 0.15));
        }

        .envelope-tampa .texto-clique {
            font-family: 'Quicksand', sans-serif;
            font-weight: 300;
            color: #7a4a5a;
            font-size: 0.8rem;
            letter-spacing: 5px;
            text-transform: uppercase;
            opacity: 0.6;
            margin-top: 4px;
        }

        .envelope-tampa .seta {
            font-size: 18px;
            display: block;
            margin-top: 2px;
            animation: sobe-desce 1.8s infinite;
        }

        @keyframes sobe-desce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-6px); }
        }

        /* Corpo do envelope (mensagem interna) */
        .envelope-corpo {
            padding: 0 20px 25px;
            background: linear-gradient(145deg, #fce8ee, #f5d4df);
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.8s cubic-bezier(0.34, 1.56, 0.64, 1), padding 0.6s ease;
            padding: 0 20px;
        }

        .envelope-box.aberto .envelope-corpo {
            max-height: 400px;
            padding: 25px 20px 30px;
        }

        .envelope-box.aberto .envelope-tampa {
            border-bottom: 2px solid rgba(255, 200, 215, 0.1);
            background: linear-gradient(145deg, #e8b4c4, #dda0b0);
        }

        .envelope-box.aberto .envelope-tampa .selo {
            animation: pulse 1.5s infinite;
        }

        .envelope-mensagem {
            font-family: 'Playfair Display', Georgia, serif;
            font-style: italic;
            font-size: clamp(1.1rem, 1.6vw, 1.4rem);
            color: #4a2a36;
            text-align: center;
            line-height: 1.9;
            letter-spacing: 0.5px;
        }

        .envelope-mensagem .coracao-env {
            color: #ff6b8a;
            font-style: normal;
        }

        .envelope-mensagem .anel-env {
            color: #c99aab;
            font-style: normal;
        }

        .envelope-assinatura {
            font-family: 'Great Vibes', cursive;
            font-size: 1.5rem;
            color: #8a5a6a;
            margin-top: 14px;
            text-align: center;
            letter-spacing: 2px;
        }

        /* Corações saindo */
        .heart-burst {
            position: fixed;
            pointer-events: none;
            z-index: 100;
            font-size: 26px;
            animation: estourar 1.2s ease-out forwards;
        }

        @keyframes estourar {
            0% { opacity: 1; transform: translate(0, 0) scale(1) rotate(0); }
            100% { opacity: 0; transform: translate(var(--tx), var(--ty)) scale(0.2) rotate(720deg); }
        }

        /* Rodapé */
        .rodape {
            margin-top: 45px;
            padding-top: 30px;
            border-top: 1px solid rgba(255, 150, 180, 0.05);
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            opacity: 0;
            transform: translateY(30px);
            transition: all 1s ease 0.5s;
        }

        .rodape.revelado {
            opacity: 1;
            transform: translateY(0);
        }

        .assinatura {
            font-family: 'Great Vibes', cursive;
            font-size: clamp(1.3rem, 2vw, 1.8rem);
            background: linear-gradient(135deg, #ffc8d8, #ff8aa8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .assinatura .flor {
            font-size: 30px;
            -webkit-text-fill-color: initial;
            animation: balanca 4s infinite;
        }

        @keyframes balanca {
            0%, 100% { transform: rotate(-6deg); }
            50% { transform: rotate(6deg); }
        }

        .selo-rodape {
            font-size: 24px;
            letter-spacing: 14px;
            opacity: 0.3;
            animation: pulse-selo 3s infinite alternate;
        }

        @keyframes pulse-selo {
            0% { opacity: 0.15; letter-spacing: 10px; }
            100% { opacity: 0.6; letter-spacing: 20px; }
        }

        .data {
            font-family: 'Quicksand', sans-serif;
            font-weight: 300;
            font-size: 0.7rem;
            color: #8a6a78;
            letter-spacing: 6px;
            text-transform: uppercase;
            opacity: 0.2;
        }

        /* Responsivo */
        @media (max-width: 768px) {
            .container {
                padding: 35px 28px 30px;
                border-radius: 50px;
            }
            .texto p {
                text-indent: 2em;
                font-size: 1rem;
                line-height: 2.2;
            }
            .envelope-box {
                width: 280px;
            }
            .envelope-mensagem {
                font-size: 1rem;
            }
            .envelope-assinatura {
                font-size: 1.2rem;
            }
            .divisoria .linha {
                width: 50px;
            }
        }

        @media (max-width: 480px) {
            .container {
                padding: 22px 16px 22px;
                border-radius: 35px;
            }
            .texto {
                font-size: 0.95rem;
                line-height: 2;
            }
            .texto p {
                text-indent: 1.2em;
                margin-bottom: 14px;
            }
            h1 {
                font-size: 2rem;
            }
            .sub {
                letter-spacing: 6px;
                font-size: 0.55rem;
            }
            .icone {
                font-size: 38px;
            }
            .envelope-box {
                width: 220px;
            }
            .envelope-tampa .selo {
                font-size: 32px;
            }
            .envelope-tampa .texto-clique {
                font-size: 0.65rem;
                letter-spacing: 3px;
            }
            .envelope-mensagem {
                font-size: 0.85rem;
                line-height: 1.6;
            }
            .envelope-assinatura {
                font-size: 1rem;
            }
            .rodape {
                flex-direction: column;
                text-align: center;
                gap: 8px;
            }
            .assinatura {
                font-size: 1.1rem;
                flex-wrap: wrap;
                justify-content: center;
            }
            .selo-rodape {
                font-size: 18px;
                letter-spacing: 8px;
            }
            .data {
                font-size: 0.55rem;
                letter-spacing: 4px;
            }
            .petal {
                font-size: 16px !important;
            }
        }
    </style>
</head>
<body>

    <!-- Pétalas -->
    <div class="petals">
        <div class="petal">🌸</div>
        <div class="petal">🌹</div>
        <div class="petal">🌸</div>
        <div class="petal">🌹</div>
        <div class="petal">🌸</div>
        <div class="petal">🌹</div>
        <div class="petal">🌸</div>
        <div class="petal">🌹</div>
        <div class="petal">🌸</div>
        <div class="petal">🌹</div>
    </div>

    <!-- Container -->
    <div class="container">

        <div class="topo">
            <span class="icone">💍</span>
            <h1>Para minha baixinha maravilhosa</h1>
            <div class="sub">✦ eterna namorada · futura esposa ✦</div>
            <div class="divisoria">
                <span class="linha"></span>
                <span class="coracao">❤️</span>
                <span class="linha"></span>
            </div>
        </div>

        <div class="texto" id="textoContainer">

            <p><span class="destaque">Depois de um tempo</span> sem escrever algo para minha amada, aqui estou novamente.</p>

            <p>Meu amor, a primeira vez que te vi, me veio vários pensamentos — pensando que você poderia não gostar de algo em mim. Não sei o porquê. Ainda mais quando você me chamou pra sua casa para conhecer seus pais — pensei que eles não poderiam gostar de mim. Também não sei o porquê.</p>

            <p>Mas quando ficamos sozinhos, fui perdendo a timidez aos poucos. Logo pensando como iria te pedir em namoro — cheio de vergonha, até as mãos estavam suando na hora. E pensando como seria nosso primeiro beijo.</p>

            <p>Mas não sabia que sairia por causa de uma <span class="destaque-forte">provocação minha</span> <span class="emoji">🤭</span> Mas logo após isso, dei outro — e você ficou sem jeito. E logo após isso, <span class="destaque-forte">te pedi em namoro</span>. Finalmente você aceitou. E finalmente estávamos namorando oficialmente.</p>

            <p>Mas quase que esse pedido não saía, porque a <span class="destaque">caixa da aliança ficou presa no meu bolso</span> <span class="emoji">😅</span> Mas depois que você disse <span class="grito">"sim"</span>, soube que verdadeiramente você era a mulher para minha vida inteira. Assim espero.</p>

            <p>E cada dia agradeço a Deus por te ter em minha vida. Logo após isso, você me deu o presente que você fez — e admito que fiquei a noite toda vendo e revendo cada texto, cada detalhe que havia no presente. <span class="destaque-forte">Seu cheiro em todo o presente</span> — ali me senti amado verdadeiramente.</p>

            <p>E logo após ver tanto o seu presente, fiquei pensativo — pensando em quando eu poderia te ver novamente. Mas tudo é no tempo de Deus.</p>

            <p>Agradeço muito por cada segundo que eu tive ao seu lado: cada abraço, cada beijo, cada vez que eu olhava para as estrelas que haviam nas constelações presentes em <span class="destaque-forte">seus olhos</span> <span class="emoji">✨</span></p>

            <p>Nesses poucos dias, <span class="destaque-forte">eu fui o cara mais feliz do mundo inteiro</span> por ter amado um anjo que me chama de <span class="destaque">"meu amor"</span>, que me faz meu dia muito mais feliz a cada dia que se passa, anima meus dias com seu sorriso, suas brincadeiras.</p>

            <p>Nunca irei me arrepender de ter te conhecido, porque você me fez uma nova pessoa — melhorada — e que principalmente me fez <span class="destaque-forte">acreditar no amor</span> em meio a esse mundo de pessoas desapegadas.</p>

            <p>E hoje acredito que achei minha <span class="destaque">eterna paixão</span>, minha eterna namorada e futura esposa. E amo nosso amor tão doce e puro. <span class="emoji">🤍</span></p>

            <p>Por isso, meu amor, prometo com o fundo do meu coração: <span class="destaque-forte">te amar e cuidar de você a cada dia</span> com todo amor que há em meu coração.</p>

            <p>E caso um dia eu faça algo, quero que me diga — pois não acho justo nos rirmos juntos e você chorar ou ficar desanimada sozinha. Pois tenho o <span class="destaque-forte">maior medo do mundo de te perder</span> — porque se eu te perder, significa que me perderei junto.</p>

            <p>Por isso, a cada dia quando possível, digo o quanto eu te amo e o quanto você me faz bem. Tanto que as pessoas ao meu redor perceberam minha felicidade — meus sorrisos do nada, pensando em você.</p>

            <p><span class="destaque-forte">E isso resume muito meu amor por você</span>, minha baixinha maravilhosa — e agora minha namorada e futuramente <span class="destaque-forte">minha eterna esposa</span> <span class="emoji">🤍💍</span></p>

        </div>

        <!-- ENVELOPE SIMPLES E FUNCIONAL -->
        <div class="envelope-wrapper">
            <div class="envelope-box" id="envelopeBox">
                <div class="envelope-tampa">
                    <span class="selo">💌</span>
                    <span class="texto-clique">Clique para abrir</span>
                    <span class="seta">👇</span>
                </div>
                <div class="envelope-corpo">
                    <div class="envelope-mensagem">
                        Eu te quero tanto, tanto você perto<br>
                        e nada vai mudar o que eu sinto por você<br>
                        nunca vai passar<br>
                        te amar me faz tão feliz
                        <div style="margin-top: 10px; font-size: 1.3em;">
                            <span class="coracao-env">🤍</span>
                            <span class="anel-env">💍</span>
                        </div>
                    </div>
                    <div class="envelope-assinatura">— para sempre</div>
                </div>
            </div>
        </div>

        <!-- Rodapé -->
        <div class="rodape" id="rodape">
            <div class="assinatura">
                <span class="flor">🌹</span>
                Com todo amor do mundo
            </div>
            <div class="selo-rodape">❤️‍🔥 🤍 💕</div>
            <div class="data">✦ para sempre ✦</div>
        </div>

    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {

            // Revelar texto ao rolar
            const paragrafos = document.querySelectorAll('.texto p');
            const rodape = document.getElementById('rodape');

            function isVisible(el) {
                const rect = el.getBoundingClientRect();
                const winH = window.innerHeight || document.documentElement.clientHeight;
                return rect.top < winH - 80 && rect.bottom > 0;
            }

            function revelar() {
                paragrafos.forEach(p => {
                    if (isVisible(p) && !p.classList.contains('revelado')) {
                        p.classList.add('revelado');
                    }
                });
                if (isVisible(rodape) && !rodape.classList.contains('revelado')) {
                    rodape.classList.add('revelado');
                }
            }

            setTimeout(revelar, 300);
            window.addEventListener('scroll', revelar);
            window.addEventListener('resize', revelar);

            // ENVELOPE
            const envelopeBox = document.getElementById('envelopeBox');
            let aberto = false;

            envelopeBox.addEventListener('click', function(e) {
                e.stopPropagation();
                if (!aberto) {
                    this.classList.add('aberto');
                    aberto = true;
                    // Corações saindo
                    for (let i = 0; i < 16; i++) {
                        setTimeout(() => criarCoracao(), i * 70);
                    }
                } else {
                    this.classList.remove('aberto');
                    aberto = false;
                }
            });

            function criarCoracao() {
                const coracao = document.createElement('div');
                coracao.className = 'heart-burst';
                const emojis = ['❤️', '💕', '💗', '❤️‍🔥', '💖', '🤍'];
                coracao.textContent = emojis[Math.floor(Math.random() * emojis.length)];
                const rect = envelopeBox.getBoundingClientRect();
                const x = rect.left + rect.width / 2 + (Math.random() - 0.5) * 140;
                const y = rect.top + rect.height / 2 + (Math.random() - 0.5) * 60;
                coracao.style.left = x + 'px';
                coracao.style.top = y + 'px';
                const ang = Math.random() * 360;
                const dist = 70 + Math.random() * 130;
                const tx = Math.cos(ang) * dist;
                const ty = Math.sin(ang) * dist - 80;
                coracao.style.setProperty('--tx', tx + 'px');
                coracao.style.setProperty('--ty', ty + 'px');
                coracao.style.fontSize = (18 + Math.random() * 30) + 'px';
                document.body.appendChild(coracao);
                setTimeout(() => coracao.remove(), 1400);
            }

        });
    </script>

</body>
</html>w
